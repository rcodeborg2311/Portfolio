---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
	title="Contact: Ridham Patel"
	description="Get in touch with Ridham Patel — quant finance, systems programming, recruiting, or anything in between."
>
	<section class="content-shell py-16">
		<div class="max-w-2xl space-y-14">

			<!-- Header -->
			<div class="space-y-5">
				<p class="text-sm font-bold uppercase tracking-widest text-base-400">Contact</p>
				<h1 class="text-5xl font-extrabold text-base-900 leading-tight tracking-tight">
					Let's talk.
				</h1>
				<p class="text-xl text-base-600 leading-relaxed">
					I'm always happy to connect about quant finance, systems programming,
					recruiting, or anything that sits at the intersection of math and markets.
				</p>
			</div>

			<!-- Direct links -->
			<div class="space-y-4">
				<h2 class="text-sm font-bold uppercase tracking-widest text-base-400">Reach Me Directly</h2>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

					<a
						href="mailto:ridham412work@gmail.com"
						class="group p-6 rounded-xl border border-base-200 bg-base-50 dark:bg-base-900 dark:border-base-700 hover:border-base-400 dark:hover:border-base-500 transition-colors space-y-2 block"
					>
						<p class="text-xs font-bold uppercase tracking-widest text-base-400">Email</p>
						<p class="text-base-900 font-semibold text-sm group-hover:underline">ridham412work@gmail.com</p>
						<p class="text-base-500 text-xs">Best for detailed questions, recruiting, or collaboration.</p>
					</a>

					<a
						href="https://www.linkedin.com/in/ridham-patel-2003as12/"
						target="_blank"
						rel="noopener noreferrer"
						class="group p-6 rounded-xl border border-base-200 bg-base-50 dark:bg-base-900 dark:border-base-700 hover:border-base-400 dark:hover:border-base-500 transition-colors space-y-2 block"
					>
						<p class="text-xs font-bold uppercase tracking-widest text-base-400">LinkedIn</p>
						<p class="text-base-900 font-semibold text-sm group-hover:underline">ridham-patel-2003as12</p>
						<p class="text-base-500 text-xs">Recruiting, networking, and professional updates.</p>
					</a>

					<a
						href="https://github.com/rcodeborg2311"
						target="_blank"
						rel="noopener noreferrer"
						class="group p-6 rounded-xl border border-base-200 bg-base-50 dark:bg-base-900 dark:border-base-700 hover:border-base-400 dark:hover:border-base-500 transition-colors space-y-2 block"
					>
						<p class="text-xs font-bold uppercase tracking-widest text-base-400">GitHub</p>
						<p class="text-base-900 font-semibold text-sm group-hover:underline">rcodeborg2311</p>
						<p class="text-base-500 text-xs">Code, projects, and contributions.</p>
					</a>

				</div>
			</div>

			<!-- Good topics -->
			<div class="space-y-4">
				<h2 class="text-sm font-bold uppercase tracking-widest text-base-400">Good Topics to Reach Out About</h2>
				<ul class="space-y-3 text-base text-base-600">
					<li class="flex gap-4 items-start">
						<span class="mt-1 h-1.5 w-1.5 rounded-full bg-base-900 shrink-0"></span>
						<span>Quant Developer or Quant Researcher internship opportunities for Summer 2027</span>
					</li>
					<li class="flex gap-4 items-start">
						<span class="mt-1 h-1.5 w-1.5 rounded-full bg-base-900 shrink-0"></span>
						<span>Questions about my projects: the order book engine, stat arb platform, or RL market-making agent</span>
					</li>
					<li class="flex gap-4 items-start">
						<span class="mt-1 h-1.5 w-1.5 rounded-full bg-base-900 shrink-0"></span>
						<span>Anything related to market microstructure, HFT systems, or quantitative research</span>
					</li>
					<li class="flex gap-4 items-start">
						<span class="mt-1 h-1.5 w-1.5 rounded-full bg-base-900 shrink-0"></span>
						<span>Open-source collaboration in the quant or systems space</span>
					</li>
				</ul>
			</div>

			<!-- Response note -->
			<div class="border-t border-base-200 pt-10">
				<p class="text-sm text-base-400 leading-relaxed">
					I try to respond to every message. Email is the most reliable way to reach me.
				</p>
			</div>

		</div>
	</section>
</PageLayout>
