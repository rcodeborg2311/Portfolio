---
import PageLayout from '../layouts/PageLayout.astro';
import Social from '../components/Social.astro';
---

<PageLayout
	title="Contact: Ridham Patel"
	description="Get in touch with Ridham Patel — quant finance, systems programming, recruiting, or anything in between."
>
	<section class="content-shell py-16">
		<div class="max-w-2xl space-y-14">

			<!-- Header -->
			<div class="space-y-4 anim anim-1">
				<p class="eyebrow" style="font-size:0.85rem;letter-spacing:0.32em;font-weight:700;">Contact</p>
				<h1 class="text-2xl font-bold leading-tight">Let's talk.</h1>
				<p class="opacity-60 leading-relaxed text-sm">
					I'm always happy to connect about quant finance, systems programming,
					recruiting, or anything that sits at the intersection of math and markets.
				</p>
			</div>

			<!-- Direct links -->
			<div class="space-y-4 anim anim-2">
				<h2 class="text-base font-bold uppercase tracking-widest">Reach Me Directly</h2>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-3">

					<a
						href="mailto:ridham412work@gmail.com"
						class="group flex flex-col p-5 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color:var(--color-accent)] transition-colors duration-200 space-y-3"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 group-hover:stroke-[color:var(--color-accent)] transition-all duration-200">
							<rect width="20" height="16" x="2" y="4" rx="2"/>
							<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
						</svg>
						<div class="space-y-1">
							<p class="font-bold text-sm uppercase tracking-widest">Email</p>
							<p class="text-sm opacity-70 group-hover:opacity-100 break-all transition-opacity duration-200">ridham412work@gmail.com</p>
							<p class="text-xs opacity-40 leading-relaxed">Best for recruiting or collaboration.</p>
						</div>
					</a>

					<a
						href="https://www.linkedin.com/in/ridham-patel-2003as12/"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col p-5 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color:var(--color-accent)] transition-colors duration-200 space-y-3"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="opacity-70 group-hover:opacity-100 group-hover:text-[#0a66c2] transition-all duration-200">
							<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
						</svg>
						<div class="space-y-1">
							<p class="font-bold text-sm uppercase tracking-widest">LinkedIn</p>
							<p class="text-sm opacity-70 group-hover:opacity-100 transition-opacity duration-200">ridham-patel-2003as12</p>
							<p class="text-xs opacity-40 leading-relaxed">Networking and professional updates.</p>
						</div>
					</a>

					<a
						href="https://github.com/rcodeborg2311"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col p-5 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color:var(--color-accent)] transition-colors duration-200 space-y-3"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="opacity-70 group-hover:opacity-100 transition-all duration-200">
							<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
						</svg>
						<div class="space-y-1">
							<p class="font-bold text-sm uppercase tracking-widest">GitHub</p>
							<p class="text-sm opacity-70 group-hover:opacity-100 transition-opacity duration-200">rcodeborg2311</p>
							<p class="text-xs opacity-40 leading-relaxed">Code, projects, and contributions.</p>
						</div>
					</a>

				</div>
			</div>

			<!-- Response note -->
			<div class="border-t border-[color:var(--color-border)] pt-10">
				<p class="opacity-50 text-sm leading-relaxed">
					I try to respond to every message. Email is the most reliable way to reach me.
				</p>
			</div>

		</div>
	</section>

	<Social />
</PageLayout>
