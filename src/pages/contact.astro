---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
	title="Contact: Ridham Patel"
	description="Get in touch with Ridham Patel — quant finance, systems programming, recruiting, or anything in between."
>
	<section class="content-shell py-16">
		<div class="max-w-2xl space-y-14">

			<!-- Header -->
			<div class="space-y-5">
				<p class="text-sm font-bold uppercase tracking-widest text-base-400">Contact</p>
				<h1 class="text-5xl font-extrabold text-base-900 leading-tight tracking-tight">
					Let's talk.
				</h1>
				<p class="text-xl text-base-600 leading-relaxed">
					I'm always happy to connect about quant finance, systems programming,
					recruiting, or anything that sits at the intersection of math and markets.
				</p>
			</div>

			<!-- Direct links -->
			<div class="space-y-4">
				<h2 class="text-sm font-bold uppercase tracking-widest text-base-400">Reach Me Directly</h2>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

					<a
						href="mailto:ridham412work@gmail.com"
						class="group flex flex-col items-center text-center p-6 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color-mix(in_oklab,var(--color-ink)_30%,transparent)] transition-colors space-y-2 block"
					>
						<p class="text-xs font-bold uppercase tracking-widest">Email</p>
						<p class="font-semibold text-sm group-hover:underline break-all">ridham412work@gmail.com</p>
						<p class="text-xs opacity-70">Best for detailed questions, recruiting, or collaboration.</p>
					</a>

					<a
						href="https://www.linkedin.com/in/ridham-patel-2003as12/"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col items-center text-center p-6 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color-mix(in_oklab,var(--color-ink)_30%,transparent)] transition-colors space-y-2 block"
					>
						<p class="text-xs font-bold uppercase tracking-widest">LinkedIn</p>
						<p class="font-semibold text-sm group-hover:underline">ridham-patel-2003as12</p>
						<p class="text-xs opacity-70">Recruiting, networking, and professional updates.</p>
					</a>

					<a
						href="https://github.com/rcodeborg2311"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col items-center text-center p-6 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color-mix(in_oklab,var(--color-ink)_30%,transparent)] transition-colors space-y-2 block"
					>
						<p class="text-xs font-bold uppercase tracking-widest">GitHub</p>
						<p class="font-semibold text-sm group-hover:underline">rcodeborg2311</p>
						<p class="text-xs opacity-70">Code, projects, and contributions.</p>
					</a>

				</div>
			</div>

			<!-- Response note -->
			<div class="border-t border-[color:var(--color-border)] pt-10">
				<p class="text-sm opacity-70 leading-relaxed">
					I try to respond to every message. Email is the most reliable way to reach me.
				</p>
			</div>

		</div>
	</section>
</PageLayout>
