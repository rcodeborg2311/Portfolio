---
import PageLayout from '../layouts/PageLayout.astro';
import Social from '../components/Social.astro';
---

<PageLayout
	title="Contact: Ridham Patel"
	description="Get in touch with Ridham Patel — quant finance, systems programming, recruiting, or anything in between."
>
	<section class="content-shell py-16">
		<div class="max-w-2xl space-y-14">

			<!-- Header -->
			<div class="space-y-4 anim anim-1">
				<p class="eyebrow" style="font-size:0.85rem;letter-spacing:0.32em;font-weight:700;">Contact</p>
				<h1 class="text-2xl font-bold leading-tight">Let's talk.</h1>
				<p class="opacity-60 leading-relaxed text-sm">
					I'm always happy to connect about quant finance, systems programming,
					recruiting, or anything that sits at the intersection of math and markets.
				</p>
			</div>

			<!-- Direct links -->
			<div class="space-y-4 anim anim-2">
				<h2 class="text-base font-bold uppercase tracking-widest">Reach Me Directly</h2>
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-3">

					<a
						href="mailto:ridham412work@gmail.com"
						class="group flex flex-col p-5 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color:var(--color-ink)] transition-colors duration-200 space-y-1.5"
					>
						<p class="eyebrow">Email</p>
						<p class="font-semibold text-sm group-hover:underline underline-offset-2 break-all">ridham412work@gmail.com</p>
						<p class="text-xs opacity-45 leading-relaxed">Best for detailed questions, recruiting, or collaboration.</p>
					</a>

					<a
						href="https://www.linkedin.com/in/ridham-patel-2003as12/"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col p-5 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color:var(--color-ink)] transition-colors duration-200 space-y-1.5"
					>
						<p class="eyebrow">LinkedIn</p>
						<p class="font-semibold text-sm group-hover:underline underline-offset-2">ridham-patel-2003as12</p>
						<p class="text-xs opacity-45 leading-relaxed">Recruiting, networking, and professional updates.</p>
					</a>

					<a
						href="https://github.com/rcodeborg2311"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col p-5 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] hover:border-[color:var(--color-ink)] transition-colors duration-200 space-y-1.5"
					>
						<p class="eyebrow">GitHub</p>
						<p class="font-semibold text-sm group-hover:underline underline-offset-2">rcodeborg2311</p>
						<p class="text-xs opacity-45 leading-relaxed">Code, projects, and contributions.</p>
					</a>

				</div>
			</div>

			<!-- Response note -->
			<div class="border-t border-[color:var(--color-border)] pt-10">
				<p class="opacity-50 text-sm leading-relaxed">
					I try to respond to every message. Email is the most reliable way to reach me.
				</p>
			</div>

		</div>
	</section>

	<Social />
</PageLayout>
