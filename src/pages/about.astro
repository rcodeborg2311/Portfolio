---
import PageLayout from '../layouts/PageLayout.astro';
import { getImage } from 'astro:assets';
import rawP0 from '../assets/photo-1.jpg';
import rawP1 from '../assets/photo-featured.jpg';
import rawP2 from '../assets/photo-2.jpg';
import rawP3 from '../assets/photo-3.jpg';
import rawP4 from '../assets/photo-4.jpg';
import rawP5 from '../assets/photo-5.jpg';

const imgs = await Promise.all(
	[rawP0, rawP1, rawP2, rawP3, rawP4, rawP5].map(src =>
		getImage({ src, format: 'webp' })
	)
);
const photoUrls = imgs.map(i => i.src);
---

<PageLayout
	title="About: Ridham Patel"
	description="CS student at ASU. I build things, take photos, and think about markets."
>
	<section class="content-shell py-16">

		<!-- Two-column: text left, photos right -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

			<!-- Left: intro -->
			<div class="space-y-10 anim anim-1">
				<div class="space-y-5">
					<p class="eyebrow" style="font-size:0.85rem;letter-spacing:0.32em;font-weight:700;">About</p>
					<h1 class="text-2xl font-bold leading-snug">Hi, I'm Ridham.</h1>
					<p class="leading-relaxed">
						CS student at Arizona State University, graduating May 2026.
						I spend most of my time studying markets and building systems that interact with them.
						Outside of that, I play soccer, read, learn guitar, and shoot photography whenever
						I get the chance to slow down and notice something worth framing.
					</p>
				</div>

				<!-- Hobbies -->
				<div class="space-y-4">
					<h2 class="text-base font-bold uppercase tracking-widest">Outside of Code</h2>
					<div class="grid grid-cols-2 gap-3">
						{[
							{ label: "Soccer",      desc: "My reset button. Pickup games, Champions League, Sunday Leagues" },
							{ label: "Guitar",      desc: "Still a beginner. Useful reminder that consistency beats talent." },
							{ label: "Reading",     desc: "Kahneman, Hull, anything that changes how I think." },
							{ label: "Photography", desc: "Street and travel. Candid moments, light, and things easy to walk past." },
						].map(({ label, desc }) => (
							<div class="p-4 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] space-y-1">
								<p class="eyebrow" style="font-size:0.75rem;letter-spacing:0.28em;">{label}</p>
								<p class="text-sm opacity-60 leading-relaxed">{desc}</p>
							</div>
						))}
					</div>
				</div>
			</div>

			<!-- Right: photography grid -->
			<div class="space-y-3 anim anim-2">
				<div class="flex items-center justify-between mb-1">
					<h2 class="text-base font-bold uppercase tracking-widest">Photography</h2>
					<button
						id="shuffle-btn"
						aria-label="Shuffle photos"
						style="
							display: inline-flex; align-items: center; gap: 0.4rem;
							font-family: monospace; font-size: 0.7rem; letter-spacing: 0.2em;
							text-transform: uppercase; font-weight: 700;
							color: var(--color-accent); opacity: 0.75;
							background: none; border: 1px solid color-mix(in oklab, var(--color-accent) 35%, transparent);
							border-radius: 999px; padding: 0.3rem 0.85rem;
							cursor: pointer; transition: opacity 0.2s, background 0.2s;
						"
					>
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="16 3 21 3 21 8"/>
							<line x1="4" y1="20" x2="21" y2="3"/>
							<polyline points="21 16 21 21 16 21"/>
							<line x1="15" y1="15" x2="21" y2="21"/>
						</svg>
						Shuffle
					</button>
				</div>

				<!-- Featured wide -->
				<div class="w-full aspect-[4/3] rounded-2xl overflow-hidden border border-[color:var(--color-border)]">
					<img id="photo-0" src={photoUrls[0]} alt="Featured photo" class="w-full h-full object-cover" style="transition: opacity 0.35s ease;" />
				</div>

				<!-- 2-col row -->
				<div class="grid grid-cols-2 gap-3">
					<div class="aspect-square rounded-2xl overflow-hidden border border-[color:var(--color-border)]">
						<img id="photo-1" src={photoUrls[1]} alt="Photo" class="w-full h-full object-cover" style="transition: opacity 0.35s ease;" />
					</div>
					<div class="aspect-square rounded-2xl overflow-hidden border border-[color:var(--color-border)]">
						<img id="photo-2" src={photoUrls[2]} alt="Photo" class="w-full h-full object-cover" style="transition: opacity 0.35s ease;" />
					</div>
				</div>

				<!-- 3-col row -->
				<div class="grid grid-cols-3 gap-3">
					<div class="aspect-square rounded-2xl overflow-hidden border border-[color:var(--color-border)]">
						<img id="photo-3" src={photoUrls[3]} alt="Photo" class="w-full h-full object-cover" style="transition: opacity 0.35s ease;" />
					</div>
					<div class="aspect-square rounded-2xl overflow-hidden border border-[color:var(--color-border)]">
						<img id="photo-4" src={photoUrls[4]} alt="Photo" class="w-full h-full object-cover" style="transition: opacity 0.35s ease;" />
					</div>
					<div class="aspect-square rounded-2xl overflow-hidden border border-[color:var(--color-border)]">
						<img id="photo-5" src={photoUrls[5]} alt="Photo" class="w-full h-full object-cover" style="transition: opacity 0.35s ease;" />
					</div>
				</div>

			</div>

		</div>

	</section>
</PageLayout>

<script define:vars={{ photoUrls }}>
(function () {
	const btn = document.getElementById('shuffle-btn');
	const slots = [0, 1, 2, 3, 4, 5].map(i => document.getElementById('photo-' + i));
	let pool = [...photoUrls];

	function shuffle(arr) {
		const a = [...arr];
		for (let i = a.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[a[i], a[j]] = [a[j], a[i]];
		}
		// keep shuffling until at least one slot changes
		return a;
	}

	btn.addEventListener('mouseenter', () => { btn.style.opacity = '1'; btn.style.background = 'color-mix(in oklab, var(--color-accent) 10%, transparent)'; });
	btn.addEventListener('mouseleave', () => { btn.style.opacity = '0.75'; btn.style.background = 'none'; });

	btn.addEventListener('click', () => {
		let next;
		do { next = shuffle(pool); } while (next.every((v, i) => v === pool[i]));
		pool = next;

		// fade out → swap src → fade in
		slots.forEach(el => { el.style.opacity = '0'; });
		setTimeout(() => {
			slots.forEach((el, i) => { el.src = pool[i]; });
			slots.forEach(el => { el.style.opacity = '1'; });
		}, 350);
	});
})();
</script>
