---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
	title="About: Ridham Patel"
	description="CS student at ASU. I build things, take photos, and think about markets."
>
	<section class="content-shell py-16">
		<div class="max-w-2xl space-y-16">

			<!-- Intro -->
			<div class="space-y-5 anim anim-1">
				<p class="eyebrow" style="font-size:0.85rem;letter-spacing:0.32em;font-weight:700;">About</p>
				<h1 class="text-2xl font-bold leading-snug">Hi, I'm Ridham.</h1>
				<p class="leading-relaxed">
					CS student at Arizona State University, graduating May 2026.
					I spend most of my time studying markets and building systems that interact with them.
					Outside of that, I play soccer, read, learn guitar, and shoot photography whenever
					I get the chance to slow down and notice something worth framing.
				</p>
			</div>

			<!-- Photography -->
			<div class="space-y-6 anim anim-2">
				<div class="flex items-center justify-between">
					<h2 class="text-base font-bold uppercase tracking-widest">Photography</h2>
					<p class="font-mono text-xs uppercase tracking-widest opacity-40">Street · Travel · Light</p>
				</div>

				<!-- Photo grid — drop your images in src/assets/ and replace the placeholders -->
				<div class="grid grid-cols-2 gap-3">

					<!-- Large featured photo — spans both columns -->
					<div class="col-span-2 aspect-[16/9] rounded-2xl overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-surface)] flex items-center justify-center">
						<p class="font-mono text-xs uppercase tracking-widest opacity-25">Featured photo</p>
					</div>

					<!-- Row of 3 -->
					<div class="aspect-square rounded-2xl overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-surface)] flex items-center justify-center">
						<p class="font-mono text-xs uppercase tracking-widest opacity-25">Photo</p>
					</div>
					<div class="aspect-square rounded-2xl overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-surface)] flex items-center justify-center">
						<p class="font-mono text-xs uppercase tracking-widest opacity-25">Photo</p>
					</div>

					<!-- Portrait + landscape pair -->
					<div class="aspect-[3/4] rounded-2xl overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-surface)] flex items-center justify-center">
						<p class="font-mono text-xs uppercase tracking-widest opacity-25">Photo</p>
					</div>
					<div class="aspect-[3/4] rounded-2xl overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-surface)] flex items-center justify-center">
						<p class="font-mono text-xs uppercase tracking-widest opacity-25">Photo</p>
					</div>

				</div>
			</div>

		</div>
	</section>
</PageLayout>
