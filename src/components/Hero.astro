---
interface Action {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;
---

<section
  class="flex flex-col justify-between"
  style="min-height: calc(100vh - 56px);"
>
  <!-- Display name — enormous, staggered in -->
  <div class="px-6 md:px-8 pt-12 md:pt-16 pb-0" style="position:relative;">

    <!-- NYC / Wall Street skyline silhouette -->
    <div aria-hidden="true" style="
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    ">
      <svg
        viewBox="0 0 1400 480"
        preserveAspectRatio="xMidYMax meet"
        xmlns="http://www.w3.org/2000/svg"
        class="skyline-svg"
        style="position:absolute;bottom:0;left:0;width:100%;height:100%;"
      >
        <defs>
          <!-- vertical fade: transparent at top, solid at bottom -->
          <linearGradient id="skyFadeV" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="white" stop-opacity="0"/>
            <stop offset="38%"  stop-color="white" stop-opacity="0.6"/>
            <stop offset="100%" stop-color="white" stop-opacity="1"/>
          </linearGradient>
          <!-- horizontal fade: transparent far-left, solid by 30% -->
          <linearGradient id="skyFadeH" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="white" stop-opacity="0"/>
            <stop offset="22%"  stop-color="white" stop-opacity="1"/>
            <stop offset="100%" stop-color="white" stop-opacity="1"/>
          </linearGradient>
          <mask id="skyMaskV"><rect width="1400" height="480" fill="url(#skyFadeV)"/></mask>
          <mask id="skyMaskH"><rect width="1400" height="480" fill="url(#skyFadeH)"/></mask>
        </defs>

        <!--
          Lower Manhattan / Wall Street skyline.
          Clean rectilinear towers. Ground = y=480.
          Landmarks L→R: cluster → 4WTC → 3WTC → 1WTC Freedom Tower (spire)
                          → 70 Pine (Art Deco stepped crown) → 40 Wall (pyramid) → east cluster
        -->
        <g mask="url(#skyMaskV)">
          <g mask="url(#skyMaskH)">
            <path fill="currentColor" d="
              M 0,480

              L 0,402    L 52,402
              L 52,418   L 82,418
              L 82,382   L 138,382
              L 138,396  L 165,396
              L 165,358  L 225,358
              L 225,374  L 252,374
              L 252,334  L 316,334
              L 316,350  L 344,350
              L 344,308  L 412,308
              L 412,324  L 440,324
              L 440,282  L 510,282
              L 510,296  L 535,296

              L 535,258  L 590,258
              L 590,272  L 610,272

              L 610,238  L 668,238
              L 668,252  L 688,252

              L 688,190  L 700,190
              L 700,160  L 706,160
              L 706,128  L 710,128
              L 710,96   L 713,96
              L 713,70   L 715,70
              L 715,48   L 717,48
              L 717,28   L 719,28
              L 719,12   L 721,12
              L 721,4
              L 723,4
              L 723,12   L 725,12
              L 725,28   L 727,28
              L 727,48   L 729,48
              L 729,70   L 731,70
              L 731,96   L 734,96
              L 734,128  L 738,128
              L 738,160  L 744,160
              L 744,190  L 756,190
              L 756,258

              L 778,258
              L 778,236  L 838,236
              L 838,250  L 860,250

              L 860,194  L 870,194
              L 870,168  L 875,168
              L 875,146  L 879,146
              L 879,126  L 882,126
              L 882,108  L 885,108
              L 885,92   L 887,92
              L 887,78   L 889,78
              L 889,66   L 891,66
              L 891,78   L 893,78
              L 893,92   L 895,92
              L 895,108  L 898,108
              L 898,126  L 901,126
              L 901,146  L 905,146
              L 905,168  L 910,168
              L 910,194  L 920,194
              L 920,215  L 940,215

              L 940,200  L 950,200
              L 950,176  L 958,176
              L 958,164
              L 963,154  L 968,144  L 972,136  L 975,130
              L 978,136  L 981,144  L 985,154  L 990,164
              L 990,176  L 998,176
              L 998,200  L 1008,200
              L 1008,222 L 1030,222

              L 1030,205 L 1080,205
              L 1080,222 L 1110,222
              L 1110,242 L 1162,242
              L 1162,226 L 1218,226
              L 1218,246 L 1278,246
              L 1278,265 L 1345,265
              L 1345,248 L 1400,248
              L 1400,480
              Z
            "/>
          </g>
        </g>
      </svg>
    </div>
    <h1
      class="anim anim-1 font-extrabold uppercase leading-[0.88] tracking-[-0.02em] select-none"
      style="font-size: clamp(4rem, 14vw, 13rem);"
      aria-hidden="true"
    >
      {title.split(" ").map((word, i) => (
        <span class="block">{word}</span>
      ))}
    </h1>
  </div>

  <!-- Divider line — draws left→right -->
  <div class="mx-6 md:mx-8 my-8 md:my-10">
    <div class="anim-rule h-px bg-[color:var(--color-accent)]" style="opacity:0.35"></div>
  </div>

  <!-- Info bar — role / description / actions -->
  <div class="anim anim-3 px-6 md:px-8 pb-12 md:pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-start">

      <!-- Role + location -->
      <div class="space-y-1">
        {role && (
          <p class="text-base font-semibold uppercase tracking-widest">{role}</p>
        )}
        {location && (
          <p class="text-base opacity-70 tracking-wide">{location}</p>
        )}
      </div>

      <!-- Bio -->
      <div class="md:col-span-1">
        {description && (
          <p class="leading-relaxed text-base">{description}</p>
        )}
      </div>

      <!-- Actions -->
      {actions.length > 0 && (
        <div class="flex flex-col sm:flex-row md:flex-col lg:flex-row gap-3 md:items-start lg:justify-end">
          {actions.map((action, i) => (
            isExternal(action.href) ? (
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            ) : (
              <a
                href={withBase(action.href)}
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            )
          ))}
        </div>
      )}

    </div>
  </div>
</section>
