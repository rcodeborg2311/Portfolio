---
interface Action {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;
---

<section
  class="flex flex-col justify-between"
  style="min-height: calc(100vh - 56px);"
>
  <!-- Display name — enormous, staggered in -->
  <div class="px-6 md:px-8 pt-12 md:pt-16 pb-0" style="position:relative;">

    <!-- NYC / Wall Street skyline silhouette -->
    <div aria-hidden="true" style="
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    ">
      <svg
        viewBox="0 0 1400 500"
        preserveAspectRatio="xMidYMax meet"
        xmlns="http://www.w3.org/2000/svg"
        class="skyline-svg"
        style="position:absolute;bottom:0;left:0;width:100%;height:100%;"
      >
        <defs>
          <linearGradient id="skyFade" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="currentColor" stop-opacity="0"/>
            <stop offset="40%"  stop-color="currentColor" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="currentColor" stop-opacity="1"/>
          </linearGradient>
          <mask id="skyMask">
            <rect width="1400" height="500" fill="url(#skyFade)"/>
          </mask>
        </defs>

        <!--
          Wall Street / Lower Manhattan skyline — pure rectilinear building shapes.
          Ground = y=500. Landmarks L→R:
          general cluster → 4WTC → 3WTC → Freedom Tower (spire) → 70 Pine (Art Deco crown) → 40 Wall (pyramid) → trailing right
        -->
        <path
          mask="url(#skyMask)"
          fill="currentColor"
          d="
            M 0,500
            L 0,415    L 36,415
            L 36,428   L 58,428
            L 58,392   L 94,392
            L 94,405   L 114,405
            L 114,372
            L 120,372  L 120,358  L 124,358
            L 124,348  L 128,348
            L 128,358  L 132,358  L 132,372
            L 158,372
            L 158,382  L 178,382
            L 178,348  L 218,348
            L 218,360  L 240,360
            L 240,322  L 282,322
            L 282,336  L 304,336
            L 304,298  L 348,298
            L 348,312  L 368,312
            L 368,272  L 412,272
            L 412,285  L 430,285
            L 430,250  L 474,250
            L 474,262  L 490,262
            L 490,232  L 534,232

            L 534,242  L 548,242
            L 548,165
            L 554,165  L 554,135
            L 558,135  L 558,104
            L 562,104  L 562,78
            L 565,78   L 565,54
            L 567,54   L 567,34
            L 569,34   L 569,16
            L 571,16   L 571,6
            L 573,6
            L 573,16   L 575,16
            L 575,34   L 577,34
            L 577,54   L 579,54
            L 579,78   L 582,78
            L 582,104  L 586,104
            L 586,135  L 590,135
            L 590,165  L 596,165
            L 596,238

            L 618,238
            L 618,215  L 648,215
            L 648,228  L 668,228

            L 668,185
            L 676,185  L 676,158
            L 681,158  L 681,133
            L 685,133  L 685,112
            L 688,112  L 688,96
            L 690,96   L 690,82
            L 692,82   L 692,70
            L 694,70
            L 694,82   L 696,82
            L 696,96   L 698,96
            L 698,112  L 701,112
            L 701,133  L 705,133
            L 705,158  L 710,158
            L 710,185  L 716,185
            L 716,205  L 730,205

            L 730,192
            L 738,192  L 738,170
            L 746,170
            L 750,160  L 754,150  L 757,142  L 760,136
            L 763,142  L 766,150  L 770,160
            L 774,170
            L 782,170  L 782,192
            L 790,192  L 790,212
            L 808,212

            L 808,196  L 850,196
            L 850,212  L 872,212
            L 872,230  L 900,230
            L 900,215  L 932,215
            L 932,235  L 965,235
            L 965,252  L 1000,252
            L 1000,238 L 1038,238
            L 1038,256 L 1078,256
            L 1078,274 L 1120,274
            L 1120,258 L 1165,258
            L 1165,278 L 1215,278
            L 1215,294 L 1270,294
            L 1270,278 L 1330,278
            L 1330,296 L 1400,296
            L 1400,500
            Z
          "
        />
      </svg>
    </div>
    <h1
      class="anim anim-1 font-extrabold uppercase leading-[0.88] tracking-[-0.02em] select-none"
      style="font-size: clamp(4rem, 14vw, 13rem);"
      aria-hidden="true"
    >
      {title.split(" ").map((word, i) => (
        <span class="block">{word}</span>
      ))}
    </h1>
  </div>

  <!-- Divider line — draws left→right -->
  <div class="mx-6 md:mx-8 my-8 md:my-10">
    <div class="anim-rule h-px bg-[color:var(--color-accent)]" style="opacity:0.35"></div>
  </div>

  <!-- Info bar — role / description / actions -->
  <div class="anim anim-3 px-6 md:px-8 pb-12 md:pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-start">

      <!-- Role + location -->
      <div class="space-y-1">
        {role && (
          <p class="text-base font-semibold uppercase tracking-widest">{role}</p>
        )}
        {location && (
          <p class="text-base opacity-70 tracking-wide">{location}</p>
        )}
      </div>

      <!-- Bio -->
      <div class="md:col-span-1">
        {description && (
          <p class="leading-relaxed text-base">{description}</p>
        )}
      </div>

      <!-- Actions -->
      {actions.length > 0 && (
        <div class="flex flex-col sm:flex-row md:flex-col lg:flex-row gap-3 md:items-start lg:justify-end">
          {actions.map((action, i) => (
            isExternal(action.href) ? (
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            ) : (
              <a
                href={withBase(action.href)}
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            )
          ))}
        </div>
      )}

    </div>
  </div>
</section>
