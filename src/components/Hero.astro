---
interface Action {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;
---

<section
  class="flex flex-col justify-between"
  style="min-height: calc(100vh - 56px);"
>
  <!-- Display name — enormous, staggered in -->
  <div class="px-6 md:px-8 pt-12 md:pt-16 pb-0" style="position:relative;">

    <!-- NYC / Wall Street skyline silhouette -->
    <div aria-hidden="true" style="
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    ">
      <svg
        viewBox="0 0 1400 360"
        preserveAspectRatio="xMidYMax meet"
        xmlns="http://www.w3.org/2000/svg"
        class="skyline-svg"
        style="position:absolute;bottom:0;left:0;width:100%;height:100%;"
      >
        <defs>
          <linearGradient id="skyFade" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="currentColor" stop-opacity="0"/>
            <stop offset="55%"  stop-color="currentColor" stop-opacity="0.4"/>
            <stop offset="100%" stop-color="currentColor" stop-opacity="1"/>
          </linearGradient>
          <mask id="skyMask">
            <rect width="1400" height="360" fill="url(#skyFade)"/>
          </mask>
        </defs>

        <!-- Wall Street / Lower Manhattan silhouette path -->
        <path
          mask="url(#skyMask)"
          fill="currentColor"
          d="
            M 0,360
            L 0,295 L 18,295 L 18,305 L 38,305 L 38,280 L 52,280
            L 52,290 L 66,290 L 66,268 L 70,268 L 70,255 L 74,250
            L 76,242 L 78,250 L 80,255 L 84,255 L 84,268 L 92,268
            L 92,278 L 105,278 L 105,258 L 112,258 L 112,242
            L 116,242 L 116,228 L 119,222 L 122,215 L 125,222
            L 127,228 L 130,228 L 130,242 L 140,242 L 140,255
            L 152,255 L 152,238 L 158,238 L 158,220 L 162,220
            L 162,205 L 166,200 L 168,193 L 172,185 L 175,193
            L 177,200 L 180,200 L 180,212 L 188,212 L 188,225
            L 200,225 L 200,208 L 206,208 L 206,192 L 210,188
            L 212,178 L 215,168 L 218,158 L 220,145 L 222,130
            L 224,115 L 226,100 L 228,88  L 230,78  L 231,65
            L 232,52  L 233,38  L 234,25  L 235,12
            L 236,4
            L 237,12  L 238,25  L 239,38  L 240,52  L 241,65
            L 242,78  L 244,92  L 246,108 L 248,122 L 250,138
            L 252,155 L 254,168 L 256,180 L 258,192
            L 260,178 L 262,162 L 264,148 L 266,135 L 268,120
            L 269,108 L 270,96  L 271,84  L 272,72
            L 273,60  L 274,50  L 275,42
            L 276,50  L 277,60  L 278,72  L 279,84  L 280,96
            L 281,110 L 283,125 L 285,140 L 287,155 L 289,168
            L 292,180 L 295,192 L 298,200 L 305,200 L 305,185
            L 312,185 L 312,170 L 315,165 L 318,155 L 320,148
            L 323,140 L 325,133 L 327,128
            L 330,118 L 331,110 L 333,100
            L 335,92  L 336,84  L 337,78
            L 338,84  L 339,92  L 341,100
            L 343,110 L 345,122 L 347,133
            L 350,142 L 352,152 L 355,162 L 358,172
            L 362,182 L 366,192 L 370,200
            L 378,200 L 378,183 L 386,183 L 386,165
            L 390,160 L 392,152 L 394,145 L 396,138
            L 398,145 L 400,152 L 402,160
            L 405,165 L 408,172 L 412,180 L 418,190
            L 425,198 L 432,205 L 440,210
            L 450,210 L 450,194 L 458,194 L 458,178
            L 462,174 L 464,168 L 468,160 L 470,153
            L 472,160 L 475,168 L 478,176 L 481,185
            L 486,192 L 492,200 L 500,207
            L 510,207 L 510,195 L 520,195 L 520,210
            L 535,210 L 535,196 L 548,196 L 548,210
            L 562,210 L 562,225 L 578,225 L 578,212
            L 595,212 L 595,226 L 614,226 L 614,240
            L 636,240 L 636,226 L 658,226 L 658,240
            L 682,240 L 682,254 L 710,254 L 710,242
            L 742,242 L 742,256 L 776,256 L 776,268
            L 812,268 L 812,256 L 848,256 L 848,270
            L 886,270 L 886,280 L 924,280 L 924,268
            L 962,268 L 962,280 L 1000,280 L 1000,292
            L 1045,292 L 1045,280 L 1090,280 L 1090,292
            L 1140,292 L 1140,305 L 1195,305 L 1195,295
            L 1255,295 L 1255,308 L 1320,308 L 1320,298
            L 1400,298 L 1400,360
            Z
          "
        />
      </svg>
    </div>
    <h1
      class="anim anim-1 font-extrabold uppercase leading-[0.88] tracking-[-0.02em] select-none"
      style="font-size: clamp(4rem, 14vw, 13rem);"
      aria-hidden="true"
    >
      {title.split(" ").map((word, i) => (
        <span class="block">{word}</span>
      ))}
    </h1>
  </div>

  <!-- Divider line — draws left→right -->
  <div class="mx-6 md:mx-8 my-8 md:my-10">
    <div class="anim-rule h-px bg-[color:var(--color-accent)]" style="opacity:0.35"></div>
  </div>

  <!-- Info bar — role / description / actions -->
  <div class="anim anim-3 px-6 md:px-8 pb-12 md:pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-start">

      <!-- Role + location -->
      <div class="space-y-1">
        {role && (
          <p class="text-base font-semibold uppercase tracking-widest">{role}</p>
        )}
        {location && (
          <p class="text-base opacity-70 tracking-wide">{location}</p>
        )}
      </div>

      <!-- Bio -->
      <div class="md:col-span-1">
        {description && (
          <p class="leading-relaxed text-base">{description}</p>
        )}
      </div>

      <!-- Actions -->
      {actions.length > 0 && (
        <div class="flex flex-col sm:flex-row md:flex-col lg:flex-row gap-3 md:items-start lg:justify-end">
          {actions.map((action, i) => (
            isExternal(action.href) ? (
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            ) : (
              <a
                href={withBase(action.href)}
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            )
          ))}
        </div>
      )}

    </div>
  </div>
</section>
