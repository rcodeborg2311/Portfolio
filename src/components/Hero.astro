---
interface Action {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actions?: Action[];
  role?: string;
  location?: string;
}

import { withBase } from "../utils/slugify";

const isExternal = (path: string) => /^[a-z][a-z0-9+.-]*:/i.test(path) || path.startsWith('//');

const { title, description, actions = [], role, location } = Astro.props as Props;
---

<section
  class="flex flex-col justify-between"
  style="min-height: calc(100vh - 56px);"
>
  <!-- Display name — enormous, staggered in -->
  <div class="px-6 md:px-8 pt-12 md:pt-16 pb-0" style="position:relative;">

    <!-- NYC / Wall Street skyline silhouette -->
    <div aria-hidden="true" style="
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    ">
      <svg
        viewBox="0 0 1400 500"
        preserveAspectRatio="xMidYMax meet"
        xmlns="http://www.w3.org/2000/svg"
        class="skyline-svg"
        style="position:absolute;bottom:0;left:0;width:100%;height:100%;"
      >
        <defs>
          <linearGradient id="skyFade" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="currentColor" stop-opacity="0"/>
            <stop offset="40%"  stop-color="currentColor" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="currentColor" stop-opacity="1"/>
          </linearGradient>
          <mask id="skyMask">
            <rect width="1400" height="500" fill="url(#skyFade)"/>
          </mask>
        </defs>

        <!-- Wall Street / Lower Manhattan silhouette — tall buildings -->
        <path
          mask="url(#skyMask)"
          fill="currentColor"
          d="
            M 0,500
            L 0,390 L 22,390 L 22,410 L 48,410 L 48,375 L 68,375
            L 68,388 L 86,388 L 86,355 L 92,355 L 92,338 L 97,330
            L 100,318 L 103,330 L 106,338 L 112,338 L 112,355
            L 124,355 L 124,368 L 140,368 L 140,345 L 150,345
            L 150,322 L 156,322 L 156,302 L 162,295 L 165,283
            L 170,270 L 173,283 L 176,295 L 180,295 L 180,310
            L 194,310 L 194,328 L 210,328
            L 210,305 L 220,305 L 220,282 L 226,274 L 230,258
            L 235,240 L 238,225 L 242,208 L 245,190 L 248,170
            L 251,150 L 253,130 L 255,108 L 257,88
            L 258,68  L 259,50  L 260,35  L 261,20
            L 262,8
            L 263,20  L 264,35  L 265,50  L 266,68
            L 267,88  L 269,110 L 271,132 L 273,155
            L 275,175 L 277,195 L 279,215 L 281,232
            L 283,215 L 285,196 L 287,178 L 289,160
            L 291,142 L 293,124 L 295,106 L 296,90
            L 297,75  L 298,62  L 299,52
            L 300,62  L 301,75  L 302,90  L 303,106
            L 305,124 L 307,142 L 309,160 L 311,178
            L 314,196 L 317,212 L 320,228
            L 326,228 L 326,210 L 336,210 L 336,190
            L 341,183 L 345,172 L 348,162
            L 352,152 L 354,142 L 356,134
            L 358,142 L 360,152 L 363,162
            L 366,172 L 370,184 L 374,195
            L 380,208 L 386,220 L 394,230
            L 406,230 L 406,212 L 418,212 L 418,192
            L 424,185 L 427,175 L 430,164 L 432,155
            L 434,164 L 437,175 L 440,185
            L 444,194 L 449,205 L 455,215
            L 462,222 L 470,228
            L 482,228 L 482,210 L 494,210 L 494,190
            L 498,184 L 502,174 L 505,163 L 507,153
            L 509,163 L 512,174 L 515,184
            L 518,194 L 522,205 L 528,214
            L 538,222 L 548,228
            L 560,228 L 560,212 L 574,212 L 574,228
            L 592,228 L 592,212 L 608,212 L 608,228
            L 628,228 L 628,244 L 650,244 L 650,228
            L 675,228 L 675,244 L 702,244 L 702,260
            L 732,260 L 732,245 L 765,245 L 765,260
            L 800,260 L 800,275 L 838,275 L 838,260
            L 878,260 L 878,278 L 920,278 L 920,265
            L 962,265 L 962,280 L 1005,280 L 1005,295
            L 1052,295 L 1052,280 L 1100,280 L 1100,295
            L 1152,295 L 1152,312 L 1208,312 L 1208,298
            L 1268,298 L 1268,314 L 1334,314 L 1334,300
            L 1400,300 L 1400,500
            Z
          "
        />
      </svg>
    </div>
    <h1
      class="anim anim-1 font-extrabold uppercase leading-[0.88] tracking-[-0.02em] select-none"
      style="font-size: clamp(4rem, 14vw, 13rem);"
      aria-hidden="true"
    >
      {title.split(" ").map((word, i) => (
        <span class="block">{word}</span>
      ))}
    </h1>
  </div>

  <!-- Divider line — draws left→right -->
  <div class="mx-6 md:mx-8 my-8 md:my-10">
    <div class="anim-rule h-px bg-[color:var(--color-accent)]" style="opacity:0.35"></div>
  </div>

  <!-- Info bar — role / description / actions -->
  <div class="anim anim-3 px-6 md:px-8 pb-12 md:pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 items-start">

      <!-- Role + location -->
      <div class="space-y-1">
        {role && (
          <p class="text-base font-semibold uppercase tracking-widest">{role}</p>
        )}
        {location && (
          <p class="text-base opacity-70 tracking-wide">{location}</p>
        )}
      </div>

      <!-- Bio -->
      <div class="md:col-span-1">
        {description && (
          <p class="leading-relaxed text-base">{description}</p>
        )}
      </div>

      <!-- Actions -->
      {actions.length > 0 && (
        <div class="flex flex-col sm:flex-row md:flex-col lg:flex-row gap-3 md:items-start lg:justify-end">
          {actions.map((action, i) => (
            isExternal(action.href) ? (
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            ) : (
              <a
                href={withBase(action.href)}
                class={`text-base font-semibold uppercase tracking-widest transition-opacity duration-200 ${i === 0 ? 'opacity-100 hover:opacity-60' : 'opacity-70 hover:opacity-100'}`}
              >
                {action.label} →
              </a>
            )
          ))}
        </div>
      )}

    </div>
  </div>
</section>
