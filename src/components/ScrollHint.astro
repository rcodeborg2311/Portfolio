---
// No props — reads section headings from the DOM at runtime via JS
---

<div
  id="scroll-hint"
  aria-hidden="true"
  style="
    position: fixed;
    right: 1.75rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    pointer-events: auto;
    cursor: pointer;
    opacity: 1;
    transition: opacity 400ms ease;
  "
>
  <span
    id="scroll-hint-label"
    style="
      writing-mode: vertical-rl;
      text-orientation: mixed;
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--color-ink);
      opacity: 0.75;
      transition: opacity 300ms ease;
    "
  ></span>

  <svg
    id="scroll-hint-arrow"
    width="20"
    height="32"
    viewBox="0 0 10 16"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    style="opacity: 0.65; animation: sh-bounce 1.6s ease-in-out infinite;"
  >
    <line x1="5" y1="0" x2="5" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <polyline points="1,9 5,14 9,9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>
</div>

<style>
  @keyframes sh-bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }

  @media (max-width: 640px) {
    #scroll-hint { display: none; }
  }
</style>

<script>
  (function () {
    const hint  = document.getElementById('scroll-hint');
    const label = document.getElementById('scroll-hint-label');
    if (!hint || !label) return;

    // Use every h2 inside main as a scroll target — one per section heading
    const headings: Element[] = Array.from(document.querySelectorAll('main h2'));

    let currentLabel = '';
    let nextHeading: Element | null = null;

    function update() {
      const headerH = (document.querySelector('.site-header') as HTMLElement)?.offsetHeight ?? 68;
      const triggerY = headerH + 32; // just below the header

      // Find the last heading that has scrolled past the trigger line
      let activeIdx = -1;
      for (let i = 0; i < headings.length; i++) {
        if (headings[i].getBoundingClientRect().top < triggerY) {
          activeIdx = i;
        }
      }

      const nextIdx = activeIdx + 1;

      if (nextIdx >= headings.length) {
        hint.style.opacity = '0';
        nextHeading = null;
        return;
      }

      hint.style.opacity = '1';
      nextHeading = headings[nextIdx];

      const nextLabel = nextHeading.textContent?.trim() ?? '';

      if (!nextLabel) {
        hint.style.opacity = '0';
        return;
      }

      if (nextLabel !== currentLabel) {
        label.style.opacity = '0';
        setTimeout(() => {
          label.textContent = nextLabel;
          label.style.opacity = '0.75';
        }, 150);
        currentLabel = nextLabel;
      }
    }

    // Click scrolls exactly to the next heading minus header offset
    hint.addEventListener('click', () => {
      if (nextHeading) {
        const headerH = (document.querySelector('.site-header') as HTMLElement)?.offsetHeight ?? 68;
        const top = nextHeading.getBoundingClientRect().top + window.scrollY - headerH - 16;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });

    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
  })();
</script>
