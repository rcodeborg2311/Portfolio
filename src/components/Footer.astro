---
import Clock from './Clock.astro';

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-[color:var(--color-border)]">
  <div class="content-shell">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 py-6">
      <p class="font-mono text-xs tracking-widest uppercase opacity-35">
        © {year} Ridham Patel
      </p>
      <div class="flex items-center gap-4 font-mono text-xs tracking-widest uppercase opacity-35">
        <span>Phoenix, AZ</span>
        <span>·</span>
        <Clock
          timeZone="America/Phoenix"
          locale="en-US"
          hour12={true}
          showSeconds={false}
        />
      </div>
    </div>
  </div>
</footer>
