---
interface Item {
    title: string;
    description?: string;
    datetime?: string;
    dateLabel?: string;
    href?: string;
    target?: string;
    rel?: string;
    external?: boolean;
}

export interface Props {
    heading: string;
    items: Item[];
}

const heading: string = Astro.props.heading;
const items: Item[] = Astro.props.items ?? [];

function isExternal(href: string) {
    return /^https?:\/\//i.test(href);
}

const isSkills = heading.toLowerCase().includes('skill');
---

<section>
  <div class="max-w-[90rem] mx-auto px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 border-b border-[color:var(--color-border)] py-16 gap-y-10">

      <!-- Sticky label -->
      <div class="lg:sticky lg:top-24 lg:z-40 self-start">
        <h2 class="text-base font-bold uppercase tracking-widest">{heading}</h2>
      </div>

      <!-- Content -->
      <div class="md:col-span-2">

        {isSkills ? (
          /* ── Skills: clean pill groups ── */
          <div class="flex flex-col gap-6">
            {items.map((item) => (
              <div class="flex flex-col gap-2">
                <p class="font-mono text-xs uppercase tracking-widest opacity-45">{item.title}</p>
                <div class="flex flex-wrap gap-2">
                  {(item.description || '').split(',').map((s: string) => s.trim()).filter(Boolean).map((skill: string) => (
                    <span class="px-3 py-1 rounded-full border border-[color:var(--color-border)] text-xs font-semibold tracking-wide opacity-80 hover:opacity-100 hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] transition-all duration-150">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ) : (
          /* ── Experience / Education: timeline ── */
          <div class="relative flex flex-col gap-10 pl-6 border-l border-[color:var(--color-border)]">
            {items.map((item) => (
              <div class="relative group">
                {/* Timeline dot */}
                <span class="absolute -left-[1.4rem] top-[0.45rem] h-2.5 w-2.5 rounded-full border-2 border-[color:var(--color-accent)] bg-[color:var(--color-paper)] group-hover:bg-[color:var(--color-accent)] transition-colors duration-200"></span>

                <div class="flex flex-col gap-1.5">
                  {/* Date */}
                  {item.datetime && (
                    <p class="font-mono text-xs uppercase tracking-widest opacity-40">{item.dateLabel ?? item.datetime}</p>
                  )}

                  {/* Title */}
                  <h3 class="font-bold leading-snug">
                    {item.href ? (
                      <a
                        href={item.href}
                        target={item.target ?? ((item.external ?? isExternal(item.href)) ? '_blank' : undefined)}
                        rel={item.rel ?? ((item.external ?? isExternal(item.href)) ? 'noopener noreferrer' : undefined)}
                        class="hover:text-[color:var(--color-accent)] transition-colors duration-150"
                      >
                        {item.title}
                      </a>
                    ) : item.title}
                  </h3>

                  {/* Description — trimmed */}
                  {item.description && (
                    <p class="text-sm opacity-60 leading-relaxed">{item.description}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}

        <slot />
      </div>
    </div>
  </div>
</section>
