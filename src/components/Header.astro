---
import { getSite } from "../utils/consts";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";

const site = await getSite();
---

<header class="site-header">
  <nav class="h-full w-full flex items-center justify-between gap-8">

    <!-- Brand mark -->
    <a
      href="/"
      class="font-mono text-base font-bold tracking-[0.28em] uppercase opacity-70 hover:opacity-100 hover:text-[color:var(--color-accent)] transition-all duration-200 shrink-0"
      aria-label="Home"
    >RP</a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-7">
      <!-- Page links -->
      <HeaderLink href="/"        class="nav-link" activeClass="nav-link active">Home</HeaderLink>
      <HeaderLink href="/projects" class="nav-link" activeClass="nav-link active">Projects</HeaderLink>
      <HeaderLink href="/about"   class="nav-link" activeClass="nav-link active">About</HeaderLink>
      <HeaderLink href="/contact" class="nav-link" activeClass="nav-link active">Contact</HeaderLink>

      <!-- Separator — glowing dot -->
      <span class="h-1 w-1 rounded-full bg-[color:var(--color-accent)] opacity-40" aria-hidden="true"></span>

      <!-- Utilities -->
      <a
        href="https://github.com/rcodeborg2311"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link"
        aria-label="GitHub"
      >GitHub</a>
      <ThemeToggle />
    </div>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      aria-label="Toggle navigation"
      aria-pressed="false"
      class="md:hidden font-mono text-base font-bold tracking-widest uppercase opacity-60 hover:opacity-100 transition-opacity"
    >Menu</button>
  </nav>
</header>

<!-- Mobile nav overlay -->
<div
  id="mobile-nav"
  role="dialog"
  aria-label="Mobile navigation"
  aria-hidden="true"
  style="display:none;"
  class="fixed inset-0 z-[1000] flex flex-col justify-between p-8 bg-[color:var(--color-surface)]"
>
  <div class="flex items-center justify-between">
    <span class="font-mono text-xs tracking-[0.22em] uppercase opacity-50">RP</span>
    <button
      id="mobile-close"
      aria-label="Close navigation"
      class="font-mono text-xs tracking-widest uppercase opacity-50 hover:opacity-100 transition-opacity"
    >Close</button>
  </div>

  <div class="flex flex-col gap-6">
    <HeaderLink href="/"        class="nav-link text-2xl font-bold normal-case tracking-normal" activeClass="nav-link active text-2xl font-bold normal-case tracking-normal">Home</HeaderLink>
    <HeaderLink href="/projects" class="nav-link text-2xl font-bold normal-case tracking-normal" activeClass="nav-link active text-2xl font-bold normal-case tracking-normal">Projects</HeaderLink>
    <HeaderLink href="/about"   class="nav-link text-2xl font-bold normal-case tracking-normal" activeClass="nav-link active text-2xl font-bold normal-case tracking-normal">About</HeaderLink>
    <HeaderLink href="/contact" class="nav-link text-2xl font-bold normal-case tracking-normal" activeClass="nav-link active text-2xl font-bold normal-case tracking-normal">Contact</HeaderLink>
    <a href="https://github.com/rcodeborg2311" target="_blank" rel="noopener noreferrer"
      class="nav-link text-2xl font-bold normal-case tracking-normal">GitHub</a>
  </div>

  <ThemeToggle />
</div>

<script is:inline>
  const navButton  = document.getElementById("nav-toggle");
  const mobileNav  = document.getElementById("mobile-nav");
  const mobileClose = document.getElementById("mobile-close");

  function openNav() {
    mobileNav.style.display = "flex";
    mobileNav.setAttribute("aria-hidden", "false");
    navButton.setAttribute("aria-pressed", "true");
    document.body.style.overflow = "hidden";
    const first = mobileNav.querySelector("a, button");
    if (first) first.focus();
  }

  function closeNav() {
    mobileNav.style.display = "none";
    mobileNav.setAttribute("aria-hidden", "true");
    navButton.setAttribute("aria-pressed", "false");
    document.body.style.overflow = "";
    navButton.focus();
  }

  navButton?.addEventListener("click", openNav);
  mobileClose?.addEventListener("click", closeNav);

  window.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && mobileNav.style.display !== "none") closeNav();
  });

  // Close on link click inside mobile nav
  mobileNav?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeNav));

  // Debug mode (keep existing behavior)
  const DEBUG_KEY = "debug-borders";
  const applyDebug = (state) => {
    document.documentElement.dataset.debug = state === "on" ? "on" : "off";
  };
  applyDebug(localStorage.getItem(DEBUG_KEY) || "off");
</script>
